# Firebase Realtime Database and Firebase Authentication
VOICE_MESSAGING_FIREBASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com
VOICE_MESSAGING_FIREBASE_API_KEY=YOUR_FIREBASE_WEB_API_KEY
VOICE_MESSAGING_FIREBASE_EMAIL=voice-messaging@example.com
VOICE_MESSAGING_FIREBASE_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD

# Gmail OAuth (optional; required only for Airbnb email synchronization)
VOICE_MESSAGING_GMAIL_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
VOICE_MESSAGING_GMAIL_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
VOICE_MESSAGING_GMAIL_REDIRECT_URI=http://localhost:3000/gmail/callback
