{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "WhatsAppGateway": {
    "Url": "http://localhost:3000"
  },
  "AirbnbGateway": {
    "Enabled": true,
    "BaseUrl": "http://localhost:3000",
    "CheckIntervalSeconds": 60
  },
  "TimeZone": {
    "Id": "America/Mexico_City"
  },
  "Worker": {
    "IntervalSeconds": 30
  }
}
